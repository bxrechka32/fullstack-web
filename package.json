{
  "name": "digital-store",
  "version": "1.0.0",
  "description": "Интернет-магазин электроники — Практические занятия 1-12, Фронтенд и бэкенд разработка",
  "main": "server.js",
  "scripts": {
    "start:server": "node server.js",
    "start:client": "npx http-server public -p 3001 -c-1",

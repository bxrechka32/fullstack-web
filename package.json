    "dev": "npm run sass && node server.js"
  },
  "dependencies": {
    "express": "^4.18.0",
    "nanoid": "^3.3.7",
    "cors": "^2.8.5",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "sass": "^1.70.0"
  }
}
